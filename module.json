{
  "id": "pf2e-visioner",
  "title": "PF2E Visioner",
  "description": "<p>Advanced per-token visibility and cover management for Pathfinder 2E and Starfinder 2E. PF2E Visioner allows GMs to set different visibility states (observed, concealed, hidden, undetected) and cover states (none, lesser, standard, greater) for each token from each observer's perspective, with automatic PF2E condition integration and mechanical effects.</p>",
  "authors": [
    {
      "name": "RoiLeaf",
      "discord": "RoiLeaf",
      "flags": {}
    }
  ],
  "version": "8.0.3",
  "compatibility": {
    "minimum": "13.341",
    "verified": "14"
  },
  "esmodules": ["scripts/main.js"],
  "styles": [
    {
      "src": "styles/base.css"
    },
    {
      "src": "styles/colorblind.css"
    },
    {
      "src": "styles/colorblind-buttons.css"
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    },
    {
      "lang": "pl",
      "name": "Polish",
      "path": "lang/pl.json",
      "flags": {}
    },
    {
      "lang": "cn",
      "name": "简体中文",
      "path": "lang/cn.json",
      "flags": {}
    },
    {
      "lang": "fr",
      "name": "Français",
      "path": "lang/fr.json",
      "flags": {}
    }
  ],
  "packs": [
    {
      "name": "pf2e-visioner-macros",
      "label": "PF2E Visioner Macros",
      "path": "packs/pf2e-visioner-macros",
      "type": "Macro",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "documentTypes": {
    "RegionBehavior": {
      "Pf2eVisionerVisibility": {"label": "PF2E_VISIONER.REGION_BEHAVIOR.TYPES.VISIBILITY.label"},
      "Pf2eVisionerConcealment": {"label": "PF2E_VISIONER.REGION_BEHAVIOR.TYPES.CONCEALMENT.label"},
      "Pf2eVisionerCover": {"label": "PF2E_VISIONER.REGION_BEHAVIOR.TYPES.COVER.label"},
      "Pf2eVisionerSenseSuppression": {"label": "PF2E_VISIONER.REGION_BEHAVIOR.TYPES.SENSE_SUPPRESSION.label"}
    }
  },
  "socket": true,
  "flags": {
    "hotReload": {
      "extensions": ["css", "hbs", "json"],
      "paths": ["styles", "templates", "lang"]
    }
  },
  "relationships": {
    "systems": [
      {
        "id": "pf2e",
        "type": "system",
        "compatibility": {
          "minimum": "7.0.0",
          "verified": "8.0.3"
        }
      },
      {
        "id": "sf2e",
        "type": "system",
        "compatibility": {
          "minimum": "0.0.8",
          "verified": "0.0.8"
        }
      }
    ],
    "requires": [
      {
        "id": "lib-wrapper",
        "type": "module",
        "compatibility": {
          "minimum": "1.0.0"
        }
      },
      {
        "id": "socketlib",
        "type": "module",
        "manifest": "https://raw.githubusercontent.com/manuelVo/foundryvtt-socketlib/master/module.json",
        "compatibility": {}
      }
    ]
  },
  "url": "#{URL}#",
  "manifest": "#{MANIFEST}#",
  "download": "#{DOWNLOAD}#"
}
